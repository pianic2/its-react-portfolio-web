# Copy this file to .env.local for local development.
# Vite exposes VITE_* values to browser code: never store secrets here.

# Public Web3Forms access key, required to enable the contact form.
# It is embedded in the client bundle during the Vite build.
VITE_WEB3FORMS_ACCESS_KEY=

# Optional public analytics site identifier. Keep empty until the analytics
# provider and configuration receive explicit owner approval.
VITE_ANALYTICS_SITE_ID=
