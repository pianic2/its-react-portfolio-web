{
  "name": "its-react-portfolio-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint . --react-plugin --vitest-plugin --jsx-a11y-plugin --deny-warnings",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "content:validate": "vitest run src/content/contentValidation.test.ts",
    "architecture:check": "node scripts/architecture-check.mjs",
    "release:config": "node scripts/release-pages.mjs",
    "release:bundle": "node scripts/verify-pages-bundle.mjs",
    "performance:check": "node scripts/performance-check.mjs",
    "check:static": "npm run format:check && npm run lint && npm run typecheck && npm run architecture:check && npm run content:validate",
    "check:test": "npm run test",
    "check:release": "npm run build && npm run release:bundle && npm run performance:check",
    "check": "npm run check:static && npm run check:test && npm run check:release",
    "release:pages": "npm run release:config && npm run check"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@xyflow/react": "^12.11.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@iconify/react": "^4.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
